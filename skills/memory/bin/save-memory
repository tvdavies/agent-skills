#!/usr/bin/env bash
# save-memory — write a durable memory into ~/brain/memories from a rough note.
#
# Called by the memory skill so the main agent doesn't have to do the whole
# Glob/Grep/Read/Write/git dance itself. Internally shells out to `claude -p`
# with a small model to turn the rough note into a properly formatted memory
# file plus an INDEX.md hook line, then writes and pushes everything.
#
# Usage:
#   save-memory [--entity X]... [--tag Y]... "<rough note>"
#   echo "<rough note>" | save-memory [--entity X]...
#
# Exit codes: 0 ok, 2 bad args, 1 anything else. Logs to
# ~/brain/.save-memory.log; last-run summary at ~/brain/.save-memory.last.

set -euo pipefail

BRAIN_DIR="${BRAIN_DIR:-$HOME/brain}"
LOCK_FILE="$BRAIN_DIR/.save-memory.lock"
LOG_FILE="$BRAIN_DIR/.save-memory.log"
STATUS_FILE="$BRAIN_DIR/.save-memory.last"
MODEL="${SAVE_MEMORY_MODEL:-claude-haiku-4-5-20251001}"

log() { printf '[%s] %s\n' "$(date -Iseconds)" "$*" >> "$LOG_FILE"; }
status() { printf '%s\n' "$*" > "$STATUS_FILE"; }
die() { status "FAIL $(date -Iseconds): $*"; log "FAIL: $*"; echo "save-memory: $*" >&2; exit 1; }

usage() {
  cat >&2 <<EOF
usage: save-memory [--entity NAME]... [--tag NAME]... [<note>]
       echo <note> | save-memory [--entity NAME]... [--tag NAME]...

Reads a rough note (args joined, or stdin), produces a well-formed memory
file in ~/brain/memories/, updates INDEX.md, and commits+pushes.
EOF
}

entities=()
tags=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --entity) [[ $# -ge 2 ]] || { usage; exit 2; }; entities+=("$2"); shift 2 ;;
    --tag)    [[ $# -ge 2 ]] || { usage; exit 2; }; tags+=("$2"); shift 2 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) usage; exit 2 ;;
    *) break ;;
  esac
done

if [[ $# -gt 0 ]]; then
  note="$*"
elif [[ ! -t 0 ]]; then
  note="$(cat)"
else
  usage; exit 2
fi

# Trim and check
note="${note#"${note%%[![:space:]]*}"}"
note="${note%"${note##*[![:space:]]}"}"
[[ -n "$note" ]] || { usage; exit 2; }

[[ -d "$BRAIN_DIR/.git" ]] || die "brain vault not found at $BRAIN_DIR"
command -v claude >/dev/null 2>&1 || die "claude CLI not found on PATH"
command -v jq >/dev/null 2>&1 || die "jq not found on PATH"

# Serialize concurrent runs so git pull/commit/push don't race.
exec 9>"$LOCK_FILE"
flock -w 60 9 || die "could not acquire lock within 60s"

log "start: note='${note:0:120}'"

cd "$BRAIN_DIR"

git pull --rebase --quiet 2>>"$LOG_FILE" || die "git pull failed (see log)"

readme="$(cat README.md)"
index_current="$(cat memories/INDEX.md)"
existing_findings="$(ls -1 findings 2>/dev/null || true)"
existing_plans="$(ls -1 plans 2>/dev/null || true)"

# Dump all existing memory bodies so the model can (a) detect duplicates, (b)
# preserve prior content on updates, and (c) find genuine wiki-link targets.
# Cap at first ~50 to keep prompt sane as the vault grows.
existing_memories=""
while IFS= read -r mf; do
  [[ -z "$mf" || "$mf" == "INDEX.md" ]] && continue
  slug="${mf%.md}"
  existing_memories+=$'\n\n--- '"$slug"$' ---\n'"$(cat "memories/$mf")"
done < <(ls -1t memories 2>/dev/null | head -50)

entity_hint=""
if (( ${#entities[@]} > 0 )); then
  entity_hint="Caller supplied required entities: $(printf '%s, ' "${entities[@]}" | sed 's/, $//')"
fi
tag_hint=""
if (( ${#tags[@]} > 0 )); then
  tag_hint="Caller supplied required tags: $(printf '%s, ' "${tags[@]}" | sed 's/, $//')"
fi

today="$(date +%Y-%m-%d)"

read -r -d '' PROMPT <<EOF || true
You format a rough note into a well-structured memory file for an Obsidian-style vault at ~/brain/memories/. Follow the README's conventions EXACTLY.

You respond with a single JSON object matching the provided schema. No prose, no markdown fences.

# ~/brain/README.md (authoritative conventions)
$readme

# Current memories/INDEX.md
$index_current

# Existing memories (full contents) — use the slug of one of these for action="update" if the note genuinely extends or corrects it; otherwise pick a fresh kebab-case slug
$existing_memories

# Existing findings (candidates for wiki-links)
$existing_findings

# Existing plans (candidates for wiki-links)
$existing_plans

# Today's date
$today

# Caller hints
$entity_hint
$tag_hint

# Rough note from the agent
$note

# Your job
1. Decide action:
   - "update" if the rough note is additively extending, correcting, or re-dating an existing memory above. Reuse that slug.
   - "add" for a genuinely new topic. Pick a fresh, searchable kebab-case slug that does not collide with any above.
2. Produce the FULL file contents including YAML frontmatter (schema per README):
   - title, date=$today, type=memory.
   - source: one line describing the task/conversation that produced this.
   - entities: list of specific things this memory is about (repos, file paths, people, tools). Include caller-supplied entities.
   - tags: use existing conventions like kind/*, topic/*, repo/*, tool/*, person/*. Include caller-supplied tags. Prefer tags already in use across the vault.
   - Body: level-1 heading matching title, a few sentences leading with the takeaway and including the "why" / context.
   - End with a "## Related" section listing wiki-links (\`[[slug]]\`) to genuinely related existing notes. If nothing fits, write "_None yet._". Do not invent filenames.
3. UPDATE RULES (when action="update"): preserve all prior content that isn't contradicted by the rough note; merge new information in additively. Don't drop sentences from the old body unless the note explicitly supersedes them. Bump date to $today. Extend entities/tags rather than replacing.
4. Produce a one-line INDEX hook: "- [[slug]] — <one line written for a FUTURE session deciding whether to read this>". Keep it short, retrieval-focused, not a summary.
5. Produce commit message "memory: add <slug>" or "memory: update <slug>".
EOF

SCHEMA='{
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "slug", "file_contents", "index_line", "commit_message"],
  "properties": {
    "action":         {"type": "string", "enum": ["add", "update"]},
    "slug":           {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "file_contents":  {"type": "string"},
    "index_line":     {"type": "string"},
    "commit_message": {"type": "string"}
  }
}'

log "calling claude ($MODEL)"
# --json-schema forces the model to emit its output via the StructuredOutput
# tool, which appears as .structured_output on the top-level response. That
# tool has to be in the --tools allowlist; --tools "" (no tools) silently
# breaks schema enforcement. --bare is intentionally NOT used because it
# skips OAuth/keychain auth reads.
raw_response="$(
  printf '%s' "$PROMPT" | claude \
    -p \
    --model "$MODEL" \
    --output-format json \
    --no-session-persistence \
    --tools "StructuredOutput" \
    --json-schema "$SCHEMA" \
    2>>"$LOG_FILE"
)" || { log "claude exited non-zero"; die "claude invocation failed (see log)"; }

is_error="$(printf '%s' "$raw_response" | jq -r '.is_error // false')"
if [[ "$is_error" == "true" ]]; then
  err_msg="$(printf '%s' "$raw_response" | jq -r '.result // "unknown"')"
  log "claude returned is_error=true: $err_msg"
  die "claude returned an error: $err_msg"
fi

parsed="$(printf '%s' "$raw_response" | jq -ce '.structured_output' 2>>"$LOG_FILE")"
if [[ -z "$parsed" || "$parsed" == "null" ]]; then
  log "no .structured_output in response; raw: $raw_response"
  die "claude returned no structured output"
fi

action="$(jq -r '.action' <<<"$parsed")"
slug="$(jq -r '.slug' <<<"$parsed")"
file_contents="$(jq -r '.file_contents' <<<"$parsed")"
index_line="$(jq -r '.index_line' <<<"$parsed")"
commit_message="$(jq -r '.commit_message' <<<"$parsed")"

[[ -n "$slug" && "$slug" != "null" ]] || die "model output missing slug"
[[ "$slug" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "invalid slug: $slug"

memory_path="memories/$slug.md"

printf '%s' "$file_contents" > "$memory_path"
# Ensure trailing newline
[[ "$(tail -c1 "$memory_path")" == $'\n' ]] || printf '\n' >> "$memory_path"

# Update INDEX.md: replace existing line for this slug, or append to EOF.
# Strip any `_No memories yet._` placeholder along the way.
awk -v slug="$slug" -v new_line="$index_line" '
  BEGIN { replaced = 0 }
  /^_No memories yet\._[[:space:]]*$/ { next }
  {
    if (!replaced && index($0, "[[" slug "]]") > 0) {
      print new_line
      replaced = 1
      next
    }
    print
  }
  END {
    if (!replaced) print new_line
  }
' memories/INDEX.md > memories/INDEX.md.tmp && mv memories/INDEX.md.tmp memories/INDEX.md

git add "$memory_path" memories/INDEX.md
git commit -m "$commit_message" --quiet 2>>"$LOG_FILE" || die "git commit failed (see log)"
git push --quiet 2>>"$LOG_FILE" || die "git push failed; commit is local (see log)"

status "OK $(date -Iseconds): $action $slug"
log "success: $action $slug"
printf '%s %s\n' "$action" "$slug"
